
// 轮播图按钮背景颜色
.swiper-btn-color {
  background-color: $color-primary;
  // color: $color-inner!important;
}

// 轮播图底部小点点的背景颜色
.swiper-pagination-bullet-active {
  background-color: $color-primary !important;
}

// 搜索输入框聚焦时候的颜色
#local-search-input:focus {
  // background-image: linear-gradient($color-primary, $color-primary),
  // linear-gradient(#e4eaec, #e4eaec)!important;
}

// 推荐文章鼠标移入到阅读更多的颜色
.topArticle {
  .more {
    &:hover {
      color: $color-primary !important;
    }
  }
}

// 首页文章标题和阅读更多鼠标移入
.posts {
  .post-title {
    .post-title-link {
      &:hover {
        color: $color-primary;
      }
    }
  }

  .post-more {
    i {
      &:hover {
        color: $color-primary;
      }
    }
  }
}

// 首页文章tag和category鼠标移入颜色
.post-tags {
  .article-tag-list li a {
    &:hover {
      color: $color-primary;
    }
  }
}

.post-categories {
  .article-category {
    .article-category-link {
      &:hover {
        color: $color-primary;
      }
    }
  }
}

// 文章详情页的a链接颜色
.post-detail {
  a {
    color: $color-link !important;
  }
}


// 文章详情页的blockquote，md中的 > 标签的左边框和背景颜色
.post-detail {
  blockquote {
    border-left: 4px solid $color-primary;
    background-color: alpha(#f3f5f7, $color-post-contentOpacity);
  }
}

// 文章详情页的目录的左边框
.toc-link.is-active-link::before {
  background-color: $color-primary;
}

.love-runtime-widget
  .content
    padding 0 !important

.love-runtime-card
  display block
  padding 18px
  color #5d4751
  text-decoration none

.love-runtime-avatars
  display flex
  align-items center
  justify-content center
  gap 10px
  margin-bottom 14px

.love-runtime-avatar
  display flex
  flex-direction column
  align-items center
  gap 6px
  img
    width 52px
    height 52px
    border-radius 999px
    object-fit cover
  span
    font-size .72rem
    color #94697a

.love-runtime-heart
  display inline-flex
  align-items center
  justify-content center
  width 28px
  height 28px
  border-radius 999px
  background linear-gradient(135deg, #f1a0ba, #d56d92)
  color #fff

.love-runtime-copy
  text-align center

.love-runtime-title
  margin 0 0 6px
  color #7c5b69
  font-size .82rem

.love-runtime-days
  margin 0
  font-size 1.45rem
  font-weight 700
  color #61444f

.love-runtime-desc
  margin 8px 0 0
  font-size .82rem
  line-height 1.7
  color #8a6876

.github-log-widget
  header
    a
      display inline-flex
      align-items center
      gap 6px
      font-weight 700
  .content
    padding 18px

.github-log-card
  display flex
  flex-direction column
  gap 12px
  p
    margin 0
    line-height 1.85
    color #6d5660
    font-size .92rem

.github-heatmap-link
  display block
  border-radius 14px
  overflow hidden
  background #ffffff
  border 1px solid rgba(208, 215, 222, .9)
  box-shadow inset 0 1px 0 rgba(255,255,255,.75)
  padding 12px
  transition border-color .25s ease, box-shadow .25s ease
  &:hover
    border-color rgba(225, 123, 156, .4)
    box-shadow 0 10px 24px rgba(185, 129, 149, .08)

.github-heatmap
  display block
  width 100%
  height auto
  background #ffffff

.social-qrcode-trigger
  position relative
  display inline-flex
  align-items center
  justify-content center
  cursor pointer

.social-qrcode-popover
  position absolute
  left 50%
  bottom calc(100% + 14px)
  transform translateX(-50%)
  display flex
  flex-direction column
  align-items center
  gap 8px
  min-width 228px
  padding 16px
  border-radius 16px
  background rgba(255, 252, 250, .98)
  border 1px solid rgba(225, 123, 156, .18)
  box-shadow 0 14px 34px rgba(96, 72, 84, .12)
  opacity 0
  visibility hidden
  pointer-events none
  transition opacity .22s ease, transform .22s ease, visibility .22s ease
  z-index 40
  &:after
    content ''
    position absolute
    left 50%
    bottom -8px
    width 14px
    height 14px
    background rgba(255, 252, 250, .98)
    border-right 1px solid rgba(225, 123, 156, .18)
    border-bottom 1px solid rgba(225, 123, 156, .18)
    transform translateX(-50%) rotate(45deg)
  img
    display block
    width 196px
    height 196px
    object-fit contain
    border-radius 16px
    background #fff
  .social-qrcode-title
    font-size .96rem
    font-weight 600
    color #7b5060

.social-qrcode-trigger:hover .social-qrcode-popover,
.social-qrcode-trigger:focus .social-qrcode-popover,
.social-qrcode-trigger:focus-within .social-qrcode-popover
  opacity 1
  visibility visible
  transform translateX(-50%) translateY(-4px)

.footer .social-qrcode-popover
  bottom calc(100% + 18px)

.footer .social-qrcode-popover img
  width 208px
  height 208px

.footer .social-qrcode-trigger
  color inherit

.side_webinfo
  .content
    overflow visible
  .webinfo-item
    display flex
    align-items center
    justify-content space-between
    gap 12px
    div:last-child
      text-align right
      white-space nowrap

.footer
  position relative
  z-index 30

.footer-main
  display flex
  flex-direction column
  align-items center
  gap 10px
  text-align center

.footer-busuanzi
  display flex
  flex-wrap wrap
  align-items center
  justify-content center
  gap 6px 12px

.footer-busuanzi .post-meta-divider
  opacity .45

.aplayer.aplayer-fixed
  z-index 8 !important

.sidebar
  position relative
  z-index 20
