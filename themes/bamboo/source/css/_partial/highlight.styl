// // https://github.com/chriskempson/tomorrow-theme
// 可以去上面的地址，更改下面的颜色值
highlight-background = convert(hexo-config('highlight.background'));
highlight-current-line = convert(hexo-config('highlight.currentLine'));
highlight-selection = convert(hexo-config('highlight.selection'));
highlight-foreground = convert(hexo-config('highlight.foreground'));
highlight-comment = convert(hexo-config('highlight.comment'));
highlight-red = convert(hexo-config('highlight.red'));
highlight-orange = convert(hexo-config('highlight.orange'));
highlight-yellow = convert(hexo-config('highlight.yellow'));
highlight-green = convert(hexo-config('highlight.green'));
highlight-aqua = convert(hexo-config('highlight.aqua'));
highlight-blue = convert(hexo-config('highlight.blue'));
highlight-purple = convert(hexo-config('highlight.purple'));

$code-block
  background: highlight-background
  // margin: 0 article-padding * -1
  padding: 15px article-padding
  border-style: solid
  border-color: color-border
  border-width: 1px 0
  overflow: auto
  color: highlight-foreground
  // line-height: font-size * line-height

$line-numbers
  color: #666
  font-size: 1em

.post
  figure.highlight
    border-radius: 8px
    border: none
    margin: 0
    pre, code
      font-family: Menlo, Monaco, Consolas, "Courier New", monospace;
      // font-family: font-mono
    code
      background: color-background
      text-shadow: 0 1px #fff
      padding: 0 0.3em
    pre
      @extend $code-block
      code
        background: none
        text-shadow: none
        padding: 0
    @extend $code-block
    pre
      border: none
      margin: 0
      padding: 1em
      overflow-y: hidden
    .gutter + .code pre
      padding: 1em 0
    table
      margin: 0
      width: 100%
      border-collapse: inherit
    .gutter
      width: 50px
      pre
        overflow: hidden
    td
      border: none
      padding: 0
      border: 0!important
      padding: 0!important
    figcaption
      clearfix()
      font-size: 0.85em
      color: highlight-comment
      line-height: 1em
      margin-bottom: 1em
      a
        float: right
    .gutter pre
      @extend $line-numbers
      text-align: right
      padding-right: 20px
    .line
      // height: font-size * line-height
    .line.marked
      background: highlight-selection
    .gist
      // margin: 0 article-padding * -1
      border-style: solid
      border-color: color-border
      border-width: 1px 0
      background: highlight-background
      padding: 15px article-padding 15px 0
      .gist-file
        border: none
        font-family: font-mono
        margin: 0
        .gist-data
          background: none
          border: none
          .line-numbers
            @extend $line-numbers
            background: none
            border: none
            padding: 0 20px 0 0
          .line-data
            padding: 0 !important
        .highlight
          margin: 0
          padding: 0
          border: none
        .gist-meta
          background: highlight-background
          color: highlight-comment
          font: 0.85em font-sans
          text-shadow: 0 0
          padding: 0
          margin-top: 1em
          margin-left: article-padding
          a
            color: color-link
            font-weight: normal
            &:hover
              text-decoration: underline

    pre
      .comment
      .title
        color: highlight-comment
      .variable
      .attribute
      .tag
      .regexp
      .ruby .constant
      .xml .tag .title
      .xml .pi
      .xml .doctype
      .html .doctype
      .css .id
      .css .class
      .css .pseudo
        color: highlight-red
      .number
      .preprocessor
      .built_in
      .literal
      .params
      .constant
        color: highlight-orange
      .class
      .ruby .class .title
      .css .rules .attribute
        color: highlight-green
      .string
      .value
      .inheritance
      .header
      .ruby .symbol
      .xml .cdata
        color: highlight-green
      .css .hexcolor
        color: highlight-aqua
      .function
      .python .decorator
      .python .title
      .ruby .function .title
      .ruby .title .keyword
      .perl .sub
      .javascript .title
      .coffeescript .title
        color: highlight-blue
      .keyword
      .javascript .function
        color: highlight-purple

  figure.highlight
  pre:has(> code[class*="language-"])
    margin: 1.35rem 0
    border: 1px solid rgba(207, 195, 204, 0.85)
    border-radius: 18px
    background: linear-gradient(180deg, rgba(251, 245, 248, 0.98) 0, rgba(255, 255, 255, 0.98) 38px)
    box-shadow: 0 14px 34px rgba(126, 98, 112, 0.12)
    overflow: hidden
    &:before
      content: ''
      display: block
      width: 52px
      height: 12px
      margin: 12px 0 0 14px
      border-radius: 999px
      background: radial-gradient(circle at 6px 6px, #ff6b6b 0, #ff6b6b 4px, transparent 4.5px), radial-gradient(circle at 26px 6px, #ffd166 0, #ffd166 4px, transparent 4.5px), radial-gradient(circle at 46px 6px, #6bcf8d 0, #6bcf8d 4px, transparent 4.5px)

  figure.highlight
    pre
      padding: 16px 18px 18px
      overflow-x: auto
      -webkit-overflow-scrolling: touch
    .gutter
      display: none
    .gutter + .code pre
      padding: 16px 18px 18px

  pre:has(> code[class*="language-"])
    > code[class*="language-"]
      display: block
      padding: 16px 18px 18px
      background: transparent
      overflow-x: auto
      -webkit-overflow-scrolling: touch

@media (max-width: 768px)
  .post
    figure.highlight
    pre:has(> code[class*="language-"])
      border-radius: 16px
      margin: 1rem 0
      &:before
        margin: 10px 0 0 12px
    figure.highlight
      pre
      .gutter + .code pre
        padding: 14px 16px 16px
    pre:has(> code[class*="language-"])
      > code[class*="language-"]
        padding: 14px 16px 16px

.post
  figure.highlight
  pre:has(> code[class*="language-"])
    border: 1px solid #d9e5f2 !important
    border-radius: 16px
    background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%) !important
    box-shadow: 0 14px 28px rgba(148, 163, 184, 0.12)
    overflow: hidden

    &:before
      display: none !important

  figure.highlight
    figcaption
      display: flex
      align-items: center
      justify-content: flex-end
      gap: 10px
      margin: 0
      padding: 10px 12px 8px
      border-bottom: 1px solid #e2e8f0
      background: linear-gradient(180deg, rgba(255, 255, 255, .94) 0%, rgba(248, 250, 252, .98) 100%)

      span
        display: inline-flex
        align-items: center
        padding: 4px 9px
        border-radius: 999px
        border: 1px solid #dbe5ef
        background: #f1f5f9
        color: #64748b
        font-size: 11px
        line-height: 1
        font-weight: 600
        letter-spacing: .02em

.post
  figure.highlight
    position: relative
    margin: 1.35rem 0
    border: 1px solid #d9e5f2 !important
    border-radius: 16px
    background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%) !important
    box-shadow: 0 14px 28px rgba(148, 163, 184, 0.12)
    overflow: hidden

    &:before
      content: ''
      position: absolute
      top: 0
      left: 0
      right: 0
      height: 38px
      background: linear-gradient(180deg, rgba(255, 255, 255, .94) 0%, rgba(248, 250, 252, .98) 100%)
      border-bottom: 1px solid #e2e8f0

    &:after
      content: ''
      position: absolute
      top: 14px
      left: 14px
      width: 48px
      height: 10px
      background: radial-gradient(circle at 5px 5px, #ff5f57 0, #ff5f57 4px, transparent 4.5px), radial-gradient(circle at 24px 5px, #febc2e 0, #febc2e 4px, transparent 4.5px), radial-gradient(circle at 43px 5px, #28c840 0, #28c840 4px, transparent 4.5px)
      z-index: 2

    table
      position: relative
      z-index: 1
      margin: 0
      width: 100%

    figcaption
      position: absolute
      top: 0
      right: 12px
      left: 72px
      z-index: 3
      display: flex
      align-items: center
      justify-content: flex-end
      gap: 10px
      height: 38px
      margin: 0
      padding: 0
      border: 0
      background: transparent

    .gutter
      display: table-cell
      width: 56px
      background: rgba(241, 245, 249, .72)
      border-right: 1px solid #e2e8f0

    .gutter pre
      padding: 16px 12px 18px 16px
      color: #94a3b8
      font-size: 12px
      line-height: 1.78
      background: transparent
      user-select: none

    .code pre
      padding: 16px 18px 18px
      color: #334155
      font-size: 12.5px
      line-height: 1.78
      background: transparent

    .gutter + .code pre
      padding: 16px 18px 18px

  pre:has(> code[class*="language-"])
    position: relative
    margin: 1.35rem 0
    border: 1px solid #d9e5f2 !important
    border-radius: 16px
    background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%) !important
    box-shadow: 0 14px 28px rgba(148, 163, 184, 0.12)
    overflow: hidden
    padding-top: 38px

    &:before
      content: ''
      position: absolute
      top: 0
      left: 0
      right: 0
      height: 38px
      background: linear-gradient(180deg, rgba(255, 255, 255, .94) 0%, rgba(248, 250, 252, .98) 100%)
      border-bottom: 1px solid #e2e8f0

    &:after
      content: ''
      position: absolute
      top: 14px
      left: 14px
      width: 48px
      height: 10px
      background: radial-gradient(circle at 5px 5px, #ff5f57 0, #ff5f57 4px, transparent 4.5px), radial-gradient(circle at 24px 5px, #febc2e 0, #febc2e 4px, transparent 4.5px), radial-gradient(circle at 43px 5px, #28c840 0, #28c840 4px, transparent 4.5px)
      z-index: 2

    > code[class*="language-"]
      display: block
      padding: 16px 18px 18px
      color: #334155
      font-size: 12.5px
      line-height: 1.78
      background: transparent

      a
        float: none
        color: #2563eb
        font-size: 11px

    table
      border-collapse: collapse

    .gutter
      display: table-cell
      width: 52px
      background: rgba(241, 245, 249, .72)
      border-right: 1px solid #e2e8f0

    .gutter pre
      color: #94a3b8
      font-size: 12px
      text-align: right
      padding: 14px 10px 16px 14px !important
      user-select: none

    .code pre
      padding: 14px 16px 16px !important
      color: #334155
      font-size: 12.5px
      line-height: 1.78

  pre:has(> code[class*="language-"])
    > code[class*="language-"]
      color: #334155
      font-size: 12.5px
      line-height: 1.78

