<%
  var postsData = site.posts && site.posts.data ? site.posts.data.slice() : [];
  postsData.sort(function(a, b) {
    return new Date(a.date) - new Date(b.date);
  });
  var firstPost = postsData[0];
  var latestPost = postsData.length ? postsData.slice().sort(function(a, b) {
    return new Date(b.updated || b.date) - new Date(a.updated || a.date);
  })[0] : null;
  var runtimeSeed = item.type.runtime.data === 'auto' && firstPost
    ? (firstPost.date || new Date())
    : (item.type.runtime.data || new Date());
  var runtimeDate = new Date(runtimeSeed);
  var latestUpdateValue = latestPost ? (latestPost.updated || latestPost.date) : new Date();
%>
<section class="widget side_webinfo">
  <%- partial('sideHeader', {item: item}) %>
  <div class='content'>
    <div class="webinfo">
      <% if (item.type.article.on) { %>
        <div class="webinfo-item">
          <div><%= item.type.article.text %></div>
          <div><%= site.posts.length %> <%= item.type.article.unit %></div>
        </div>
      <% } %>

      <% if (item.type.runtime.on) { %>
        <div class="webinfo-item">
          <div><%= item.type.runtime.text %></div>
          <div id="webinfo-runtime-count"></div>
        </div>
        <script>
          var BirthDay = new Date(new Date('<%= runtimeDate.toISOString() %>'));
          var today = new Date();
          var timeold = (today.getTime() - BirthDay.getTime());
          var daysold = Math.floor(timeold / (24 * 60 * 60 * 1000));
          document.getElementById('webinfo-runtime-count').innerHTML = daysold + ' <%= item.type.runtime.unit %>';
        </script>
      <% } %>


      <% if (item.type.wordcount.on && theme.wordcount.on) { %>
        <div class="webinfo-item">
          <div><%= item.type.wordcount.text %></div>
          <div><%= totalcount(site) %> <%= item.type.wordcount.unit %></div>
        </div>
      <% } %>

      <% if (item.type.visitcounter.siteuv.on && item.type.visitcounter.service) { %>
        <div class="webinfo-item">
          <div><%= item.type.visitcounter.siteuv.text %></div>
          <% if (item.type.visitcounter.service == "busuanzi") { %>
          <div><span id="busuanzi_value_site_uv_widget" data-base="<%= item.counters && item.counters.siteuv_offset ? item.counters.siteuv_offset : 0 %>"><i class="fas fa-fan fa-spin fa-fw" aria-hidden="true"></i></span> <%= item.type.visitcounter.siteuv.unit %></div>
          <% } else if (item.type.visitcounter.service == "leancloud") { %>
          <!-- 暂不支持leancloud访客统计，所以这条判断无效，以后可能加上去 -->
          <div><span id="lc-uv"><span id='number'><i class="fas fa-circle-notch fa-spin fa-fw" aria-hidden="true"></i></span></span> <%= item.type.visitcounter.siteuv.unit %></div>
          <% } %>
        </div>
      <% } %>

      <% if (item.type.visitcounter.sitepv.on && item.type.visitcounter.service) { %>
        <div class="webinfo-item">
          <div><%= item.type.visitcounter.sitepv.text %></div>
          <% if (item.type.visitcounter.service == "busuanzi") {%>
          <div><span id="busuanzi_value_site_pv_widget" data-base="<%= item.counters && item.counters.sitepv_offset ? item.counters.sitepv_offset : 0 %>"><i class="fas fa-fan fa-spin fa-fw" aria-hidden="true"></i></span> <%= item.type.visitcounter.sitepv.unit %></div>
          <% } else if (item.type.visitcounter.service == "leancloud") { %>
          <div><span id="lc-sv"><span id='number'><i class="fas fa-circle-notch fa-spin fa-fw" aria-hidden="true"></i></span></span> <%= item.type.visitcounter.sitepv.unit %></div>
          <% } %>
        </div>
      <% } %>

      <% if (item.type.lastupd.on) { %>
        <div class="webinfo-item">
          <div><%= item.type.lastupd.text %></div>
          <% if (item.type.lastupd.friendlyShow) { %>
            <div id="last-update" style="display: none;"><%= new Date() %></div>
            <div id="last-update-show"><%- date(Date.now()) %> <%= item.type.lastupd.unit %></div>
          <% } else { %>
            <div><%- date(latestUpdateValue, 'YYYY-MM-DD') %><% if (item.type.lastupd.unit) { %> <%= item.type.lastupd.unit %><% } %></div>
          <% } %>
        </div>
        <% if (item.type.lastupd.friendlyShow) { %>
        <script>
          function timeago(dateTimeStamp) {
              var minute = 1000 * 60; //把分，时，天，周，半个月，一个月用毫秒表示
              var hour = minute * 60;
              var day = hour * 24;
              var week = day * 7;
              var month = day * 30;
              var now = new Date().getTime(); //获取当前时间毫秒
              var diffValue = now - dateTimeStamp; //时间差
              if (diffValue < 0) {
                  return;
              }
              var minC = diffValue / minute; //计算时间差的分，时，天，周，月
              var hourC = diffValue / hour;
              var dayC = diffValue / day;
              var weekC = diffValue / week;
              var monthC = diffValue / month;
              if (monthC >= 1 && monthC <= 3) {
                  result = " " + parseInt(monthC) + " 月前"
              } else if (weekC >= 1 && weekC <= 3) {
                  result = " " + parseInt(weekC) + " 周前"
              } else if (dayC >= 1 && dayC <= 6) {
                  result = " " + parseInt(dayC) + " 天前"
              } else if (hourC >= 1 && hourC <= 23) {
                  result = " " + parseInt(hourC) + " 小时前"
              } else if (minC >= 1 && minC <= 59) {
                  result = " " + parseInt(minC) + " 分钟前"
              } else if (diffValue >= 0 && diffValue <= minute) {
                  result = "刚刚"
              } else {
                  var datetime = new Date();
                  datetime.setTime(dateTimeStamp);
                  var Nyear = datetime.getFullYear();
                  var Nmonth = datetime.getMonth() + 1 < 10 ? "0" + (datetime.getMonth() + 1) : datetime.getMonth() + 1;
                  var Ndate = datetime.getDate() < 10 ? "0" + datetime.getDate() : datetime.getDate();
                  var Nhour = datetime.getHours() < 10 ? "0" + datetime.getHours() : datetime.getHours();
                  var Nminute = datetime.getMinutes() < 10 ? "0" + datetime.getMinutes() : datetime.getMinutes();
                  var Nsecond = datetime.getSeconds() < 10 ? "0" + datetime.getSeconds() : datetime.getSeconds();
                  result = Nyear + "-" + Nmonth + "-" + Ndate
              }
              return result;
          }
          var lastUpDate = document.getElementById('last-update').innerHTML;
          try {
            document.getElementById('last-update-show').innerHTML = timeago(new Date(lastUpDate));
          } catch (error) {
            document.getElementById('last-update-show').innerHTML = '<%- date(Date.now()) %> <%= item.type.lastupd.unit %>';
          }
        </script>
        <% } %>
      <% } %>
    </div>
  </div>
</section>
<script>
  (function syncWidgetBusuanzi() {
    var cacheKeyMap = {
      busuanzi_value_site_uv_widget: "ai-magician-site-uv",
      busuanzi_value_site_pv_widget: "ai-magician-site-pv"
    };
    function applyCached(targetId) {
      var target = document.getElementById(targetId);
      if (!target) return;
      var key = cacheKeyMap[targetId];
      var cached = key ? window.localStorage.getItem(key) : "";
      if (cached && /^\d+$/.test(cached)) {
        target.textContent = cached;
        target.dataset.offsetApplied = 'cached';
        return;
      }
      var base = Number(target.getAttribute("data-base") || "0");
      if (Number.isFinite(base) && base > 0) {
        target.textContent = String(base);
      }
    }
    function copyWithOffset(sourceId, targetId) {
      var source = document.getElementById(sourceId);
      var target = document.getElementById(targetId);
      if (!source || !target) return false;
      if (target.dataset.offsetApplied === 'true') return true;
      var raw = String(source.textContent || "").replace(/[^\d]/g, "");
      if (!raw) return false;
      var base = Number(target.getAttribute("data-base") || "0");
      var numeric = Number(raw);
      var finalValue = numeric >= base ? numeric : numeric + base;
      target.textContent = Number.isFinite(finalValue) ? String(finalValue) : raw;
      target.dataset.offsetApplied = 'true';
      var key = cacheKeyMap[targetId];
      if (key && Number.isFinite(finalValue)) {
        window.localStorage.setItem(key, String(finalValue));
      }
      return true;
    }
    function applyFallback(targetId) {
      var target = document.getElementById(targetId);
      if (!target || target.dataset.offsetApplied === 'true') return;
      var base = Number(target.getAttribute("data-base") || "0");
      if (Number.isFinite(base) && base > 0) {
        target.textContent = String(base);
        target.dataset.offsetApplied = 'fallback';
      }
    }
    var attempts = 0;
    applyCached("busuanzi_value_site_uv_widget");
    applyCached("busuanzi_value_site_pv_widget");
    function run() {
      var uvReady = copyWithOffset("busuanzi_value_site_uv", "busuanzi_value_site_uv_widget");
      var pvReady = copyWithOffset("busuanzi_value_site_pv", "busuanzi_value_site_pv_widget");
      if (!(uvReady && pvReady)) {
        attempts += 1;
        if (attempts >= 20) {
          applyFallback("busuanzi_value_site_uv_widget");
          applyFallback("busuanzi_value_site_pv_widget");
          return;
        }
        setTimeout(run, 600);
      }
    }
    run();
  })();
</script>
