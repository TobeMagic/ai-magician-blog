<section class="widget side_blogger">
  <div class='content'>
    <% if (item.avatar) { %>
      <% if (item.url) { %>
        <a class='avatar flat-box <%- item.shape %>' href='<%- url_for(item.url) %>'>
          <img src='<%- url_for(item.avatar) %>'/>
        </a>
      <% } else { %>
        <div class='avatar'>
          <img src='<%- url_for(item.avatar) %>'/>
        </div>
      <% } %>
    <% } %>
    <% if (item.title || item.subtitle || item.jinrishici) { %>
      <div class='text'>
        <% if (item.title){ %>
          <h2><%- item.title %></h2>
        <% } %>
        <% if (item.subtitle){ %>
          <%- markdown(item.subtitle) %>
        <% } %>
        <% if (item.jinrishici){ %>
          <p><span id="jinrishici-sentence"><%- item.jinrishici != true ? item.jinrishici : config.title %></span></p>
          <% if (item.jinrishici === true) { %>
            <script src="https://sdk.jinrishici.com/v2/browser/jinrishici.js" charset="utf-8"></script>
          <% } %>
        <% } %>
      </div>
    <% } %>
    <% if (item.social && item.social.length > 0) { %>
      <div class="social-wrapper">
        <% (item.social||[]).forEach(function(value){ %>
          <% if (value.qrcode && (value.icon || value.img || value.avatar)) { %>
            <span class="social social-qrcode-trigger <%- value.icon %> flat-btn" tabindex="0" role="button" aria-label="<%- value.label || '微信公众号' %>">
              <% if (value.img) { %>
                <img src="<%- value.img %>"/>
              <% } else if (value.avatar) { %>
                <img src="<%- url_for(value.avatar) %>" style="border-radius:120px"/>
              <% } %>
              <span class="social-qrcode-popover">
                <span class="social-qrcode-title"><%- value.label || '微信公众号' %></span>
                <img no-lazy src="<%- url_for(value.qrcode) %>" alt="<%- value.label || '微信公众号二维码' %>"/>
              </span>
            </span>
          <% } else if (value.url && (value.icon || value.img || value.avatar)) { %>
            <a href="<%= url_for(value.url) %>"
              class="social <%- value.icon %> flat-btn"
              target="_blank"
              rel="external nofollow noopener noreferrer">
              <% if (value.img) { %>
                <img src="<%- value.img %>"/>
              <% } else if (value.avatar) { %>
                <img src="<%- url_for(value.avatar) %>" style="border-radius:120px"/>
              <% } %>
            </a>
          <% } %>
        <%})%>
      </div>
    <% } %>
  </div>
</section>
