<!-- https://github.com/overtrue/share.js -->
<!-- 文章详情页的分享 -->
<div class="post-share-block">
  <h3>分享到这些地方</h3>
  <div class="social-share" data-sites="<%- theme.sharejs.sites %>" data-wechat-qrcode-helper="<p>微信扫一扫即可分享！</p>"></div>
</div>

<script defer src="<%- url_for('/js/shareJs/social-share.min.js') %>"></script>

<style>
  .post-share-block {
    margin: 28px 0 20px;
    padding: 18px 20px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(255,245,247,0.98), rgba(255,252,250,0.98));
    box-shadow: 0 18px 45px rgba(225, 123, 156, 0.08);
  }
  .post-share-block h3 {
    margin: 0 0 12px;
    font-size: 18px;
    color: #7b4158;
  }
  .social-share {
    margin: 20px 0;
  }
</style>

