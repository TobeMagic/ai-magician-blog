<!-- 评论所需js -->
<% if(page.comments !== false ) { %>
  <% const commentScripts = {
      "utterance": ["_partial/comment/utterance/script"],
      "beaudar": ["_partial/comment/beaudar/script"],
      "twikoo": ["_partial/comment/twikoo/script"],
      "valine": ["_partial/scripts/danmu", "_partial/comment/valine/script"],
      "gitalk": ["_partial/comment/gitalk/script"],
      "giscus": ["_partial/comment/giscus/script"],
      "waline": ["_partial/comment/waline/script"],
      "livere": ["_partial/comment/livere/script"],
      "gitment": ["_partial/comment/gitment/script"],
      "changyan": ["_partial/comment/changyan/script"],
    };
    const activePlugin = Object.keys(commentScripts).find(plugin => theme[plugin].on);
    if (activePlugin) {
      commentScripts[activePlugin].forEach(script => { %>
        <%- partial(script) %>
      <% });
    }
  %>
<% } %>

<!-- 鼠标点击特效 -->
<%- partial('_partial/scripts/cursor_effect') %>

<% if (theme.busuanzi.on) { %>
  <script>
    (function ensureBusuanzi() {
      var src = "<%- theme.CDN.busuanzi %>";
      function hasValues() {
        return [
          "busuanzi_value_site_pv",
          "busuanzi_value_site_uv",
          "busuanzi_value_page_pv",
        ].some(function (id) {
          var node = document.getElementById(id);
          return node && String(node.textContent || "").replace(/[^\d]/g, "");
        });
      }
      function injectBusuanzi(force) {
        if (!force && document.querySelector('script[data-busuanzi-loader]')) return;
        var script = document.createElement("script");
        script.async = true;
        script.src = src + (src.indexOf("?") === -1 ? "?" : "&") + "ts=" + Date.now();
        script.setAttribute("data-pjax", "");
        script.setAttribute("data-busuanzi-loader", "true");
        document.body.appendChild(script);
      }
      injectBusuanzi();
      var retries = 0;
      function retry() {
        if (hasValues() || retries >= 8) return;
        retries += 1;
        injectBusuanzi(true);
        setTimeout(retry, 3000);
      }
      setTimeout(retry, 2000);
    })();
  </script>
<% } %>

<!-- 轮播图标签 -->
<%- partial('_partial/scripts/swiperTag') %>
