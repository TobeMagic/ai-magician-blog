<!-- <link href="<%- url_for('/js/tocbot/tocbot.css') %>" rel="stylesheet">
<script src="<%- url_for('/js/tocbot/tocbot.min.js') %>"></script> -->
<%- js(theme.CDN.tocbotJs) %>
<%- css(theme.CDN.tocbotCss) %>
<script>
  var headerEl = '<%- theme.sidebar.widget_library.side_toc.heading %>',  //headers 
    content = '.post-detail',//文章容器
    idArr = {};  //标题数组以确定是否增加索引id
  
  function toChineseSectionNumber(num) {
    var digits = ['零', '一', '二', '三', '四', '五', '六', '七', '八', '九'];
    if (num <= 10) {
      return num === 10 ? '十' : digits[num];
    }
    if (num < 20) {
      return '十' + digits[num % 10];
    }
    var tens = Math.floor(num / 10);
    var ones = num % 10;
    return digits[tens] + '十' + (ones ? digits[ones] : '');
  }

  function stripHeadingIndex(rawText) {
    return String(rawText || '')
      .replace(/^[一二三四五六七八九十百千零]+、\s*/u, '')
      .replace(/^\d+(?:\.\d+){0,3}\s+/u, '')
      .trim();
  }

  function annotateNumberedHeadings() {
    var h2Index = 0;
    var h3Index = 0;
    var h4Index = 0;
    $(content).find(headerEl).each(function () {
      var $heading = $(this);
      var level = String(this.tagName || '').toLowerCase();
      var storedBaseText = $heading.attr('data-base-heading-text');
      var baseText = stripHeadingIndex(storedBaseText || $heading.text());
      var prefix = '';

      if (!baseText) {
        return;
      }

      if (level === 'h2') {
        h2Index += 1;
        h3Index = 0;
        h4Index = 0;
        prefix = toChineseSectionNumber(h2Index) + '、';
      } else if (level === 'h3') {
        if (h2Index === 0) h2Index = 1;
        h3Index += 1;
        h4Index = 0;
        prefix = h2Index + '.' + h3Index;
      } else if (level === 'h4') {
        if (h2Index === 0) h2Index = 1;
        if (h3Index === 0) h3Index = 1;
        h4Index += 1;
        prefix = h2Index + '.' + h3Index + '.' + h4Index;
      } else {
        return;
      }

      $heading.attr('data-base-heading-text', baseText);
      $heading.find('> .heading-index').remove();
      $heading.prepend('<span class="heading-index">' + prefix + ' </span>');
    });
  }

  function assignHeadingIds() {
    idArr = {};
    $(content).find(headerEl).each(function () {
      var $heading = $(this);
      var baseText = stripHeadingIndex($heading.attr('data-base-heading-text') || $heading.text());
      var headerId = baseText.replace(/[\s|\~|`|\!|\@|\#|\$|\%|\^|\&|\*|\(|\)|\_|\+|\=|\||\|\[|\]|\{|\}|\;|\:|\"|\'|\,|\<|\.|\>|\/|\?|\：|\，|\。]/g, '');
      headerId = headerId.toLowerCase();
      if (!headerId) {
        return;
      }
      if (idArr[headerId]) {
        $heading.attr('id', headerId + '-' + idArr[headerId]);
        idArr[headerId]++;
      } else {
        idArr[headerId] = 1;
        $heading.attr('id', headerId);
      }
    });
  }

  function prepareTocHeadings() {
    annotateNumberedHeadings();
    assignHeadingIds();
  }

  //add #id
  var option = {
    // Where to render the table of contents.
    tocSelector: '.toc',
    // Where to grab the headings to build the table of contents.
    contentSelector: content,
    // Which headings to grab inside of the contentSelector element.
    headingSelector: headerEl,
    scrollSmooth: true,
    scrollSmoothOffset: -70,
    // headingsOffset: -($(window).height() * 0.4 - 45),
    headingsOffset: -($(window).height() * 0.4 - 70),
    // positionFixedSelector: '.toc-main',
    // positionFixedClass: 'is-position-fixed',
    fixedSidebarOffset: 'auto',
    activeLinkClass: 'is-active-link',
    orderedList: true,
    collapseDepth: <%- theme.sidebar.widget_library.side_toc.collapseDepth %>,
    // onClick: function (e) {},
  }
  function initPostHeadingsAndToc() {
    prepareTocHeadings();
    if ($('.toc').length > 0) {
      tocbot.init(option);
      mobileTocClick();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      initPostHeadingsAndToc();
    });
  } else {
    initPostHeadingsAndToc();
  }

  window.tocScrollFn = function () {
    return bamboo.throttle(function () {
      findHeadPosition();
    }, 100)()
  }
  window.addEventListener('scroll', tocScrollFn);

  const findHeadPosition = function (top) {
    if ($('.toc-list').length <= 0) {
      return false;
    }
    setTimeout(() => {  // or DOMContentLoaded 
      autoScrollToc();
    }, 0);
  }

  const autoScrollToc = function () {
    const $activeItem = document.querySelector('.is-active-link');
    const $cardToc = document.querySelector('.toc-content');
    const activePosition = $activeItem.getBoundingClientRect().top
    const sidebarScrollTop = $cardToc.scrollTop
    if (activePosition > (document.documentElement.clientHeight - 100)) {
      $cardToc.scrollTop = sidebarScrollTop + 150
    }
    if (activePosition < 150) {
      $cardToc.scrollTop = sidebarScrollTop - 150
    }
  }

  document.addEventListener('pjax:send', function () {
    if ($('.toc').length) {
      tocbot.destroy();
    }
  });

  document.addEventListener('pjax:complete', function () {
    prepareTocHeadings();
    if ($('.toc').length) {
      tocbot.init(option);
      mobileTocClick();
    }
  });
  
  // 手机端toc按钮点击出现目录
  const mobileTocClick = function () {
    const $cardTocLayout = document.getElementsByClassName('side_toc')[0];
    const $cardToc = $cardTocLayout.getElementsByClassName('toc-content')[0];
    let right = '45px';
    if (window.innerWidth >= 551 && window.innerWidth <= 992) {
      right = '100px'
    }
    const mobileToc = {
      open: () => {
        $cardTocLayout.style.cssText = 'animation: toc-open .3s; opacity: 1; right: ' + right
      },

      close: () => {
        $cardTocLayout.style.animation = 'toc-close .2s'
        setTimeout(() => {
          $cardTocLayout.style.cssText = "opacity:''; animation: ''; right: ''"
        }, 100)
      }
    }
    document.getElementById('toc-mobile-btn').addEventListener('click', () => {
      if (window.getComputedStyle($cardTocLayout).getPropertyValue('opacity') === '0') mobileToc.open()
      else mobileToc.close()
    })

    $cardToc.addEventListener('click', (e) => {
      if (window.innerWidth < 992) { // 小于992px的时候
        mobileToc.close()
      }
    })
  }
</script>

<style>
  .post-detail .heading-index {
    color: inherit;
    font-weight: inherit;
  }
