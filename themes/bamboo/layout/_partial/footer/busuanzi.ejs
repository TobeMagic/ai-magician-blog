<!-- 不蒜子统计 -->
<span id="busuanzi_container_site_pv">
      <i class="fas fa-eye" aria-hidden="true"></i><%= __('totalVisits') %>：<span id="busuanzi_value_site_pv" data-base="<%= theme.sidebar.widget_library.side_webinfo.counters.sitepv_offset || 0 %>"></span> <%= __('times') %>
</span>
<span class="post-meta-divider">|</span>
<span id="busuanzi_container_site_uv">
      <i class="fas fa-users" aria-hidden="true"></i><%= __('numberVisitors') %>：<span id="busuanzi_value_site_uv" data-base="<%= theme.sidebar.widget_library.side_webinfo.counters.siteuv_offset || 0 %>"></span> <%= __('people') %>
</span>
<script>
  (function offsetBusuanziCounters() {
    function applyOffset(id) {
      var el = document.getElementById(id);
      if (!el) return false;
      var raw = String(el.textContent || "").replace(/[^\d]/g, "");
      if (!raw) return false;
      var base = Number(el.getAttribute("data-base") || "0");
      var finalValue = Number(raw) + base;
      el.textContent = Number.isFinite(finalValue) ? String(finalValue) : raw;
      return true;
    }
    function run() {
      var pvReady = applyOffset("busuanzi_value_site_pv");
      var uvReady = applyOffset("busuanzi_value_site_uv");
      if (!(pvReady && uvReady)) {
        setTimeout(run, 600);
      }
    }
    run();
  })();
</script>
