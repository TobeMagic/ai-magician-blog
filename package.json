{
  "name": "ai-magician-blog",
  "private": true,
  "version": "0.1.0",
  "description": "Canonical Hexo Bamboo blog for AI Magician.",
  "scripts": {
    "prepare-config": "node ./tools/fetch-github-contributions.mjs && node ./tools/write-runtime-config.mjs",
    "clean": "node ./tools/run-hexo.mjs clean",
    "build": "npm run prepare-config && node ./tools/run-hexo.mjs clean && node ./tools/run-hexo.mjs generate",
    "server": "npm run prepare-config && node ./tools/run-hexo.mjs server",
    "algolia": "npm run prepare-config && node ./tools/run-hexo.mjs algolia",
    "deploy": "npm run prepare-config && node ./tools/run-hexo.mjs deploy"
  },
  "dependencies": {
    "hexo": "^7.3.0",
    "hexo-cli": "^4.3.2",
    "hexo-algoliasearch": "^2.0.1",
    "hexo-canonical-link": "^2.0.0",
    "hexo-deployer-git": "^4.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^3.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-search": "^2.4.3",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-theme-bamboo": "^3.3.12",
    "hexo-wordcount": "^6.0.1",
    "hexo-server": "^3.0.0"
    ,
    "marked": "^15.0.12"
  }
}
